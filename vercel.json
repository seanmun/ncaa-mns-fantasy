{
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "api/_*.ts,src/lib/db/schema.ts,email-templates/*.html",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/stats/live-sync",
      "schedule": "*/30 * * * *"
    }
  ]
}
